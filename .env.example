# OpenAI-compatible API settings (works with OpenAI or local Ollama proxies)
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2:3b
LLM_TEMPERATURE=0

# Optional embeddings for alignment boost (requires a provider that supports embeddings)
# LLM_EMBEDDING_MODEL=text-embedding-3-small

# Demo/showcase: if true, the app uses heuristic extraction + rules-only classification
# (no LLM calls; fast and offline).
DEMO_MODE=false

# Rule-based labeling tolerances (used when rules can decide)
AMOUNT_REL_TOLERANCE=0.03
PERCENT_ABS_TOLERANCE=1.0

# LLM-alignment threshold
ALIGNMENT_MIN_SCORE=55
CLAIM_CHUNK_CHARS=6000

# Optional: disk cache for LLM calls
# CACHE_DIR=.cache
